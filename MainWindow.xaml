<Window x:Class="CipherLua.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CIPHER.LUA" Height="720" Width="1280"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        MinWidth="900" MinHeight="500">

    <Window.Resources>
        <FontFamily x:Key="JF">/CipherLua;component/Fonts/Jokerman.otf#Jokerman</FontFamily>
        <SolidColorBrush x:Key="Bg0"        Color="#080808"/>
        <SolidColorBrush x:Key="Bg1"        Color="#0D0D0D"/>
        <SolidColorBrush x:Key="Bg2"        Color="#141414"/>
        <SolidColorBrush x:Key="Bg3"        Color="#1A1A1A"/>
        <SolidColorBrush x:Key="Border1"    Color="#222222"/>
        <SolidColorBrush x:Key="Border2"    Color="#2A2A2A"/>
        <SolidColorBrush x:Key="TextDim"    Color="#555555"/>
        <SolidColorBrush x:Key="TextMid"    Color="#888888"/>
        <SolidColorBrush x:Key="TextBright" Color="#CCCCCC"/>
        <SolidColorBrush x:Key="TextWhite"  Color="#EEEEEE"/>
        <SolidColorBrush x:Key="AccentBrush"     Color="#C8FF00"/>
        <SolidColorBrush x:Key="AccentDimBrush"  Color="#3CC8FF00"/>
        <SolidColorBrush x:Key="AccentTextBrush" Color="#C8FF00"/>
        <!-- Tag colors -->
        <SolidColorBrush x:Key="TagOK"   Color="#00DD66"/>
        <SolidColorBrush x:Key="TagERR"  Color="#FF3333"/>
        <SolidColorBrush x:Key="TagINFO" Color="#3399FF"/>
        <SolidColorBrush x:Key="TagSYS"  Color="#AA77FF"/>
        <SolidColorBrush x:Key="TagDET"  Color="#FF9900"/>

        <!-- Pill tag style -->
        <Style x:Key="PillTag" TargetType="Border">
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Padding"      Value="5,2"/>
            <Setter Property="Margin"       Value="0,0,6,0"/>
        </Style>

        <!-- Sidebar nav button -->
        <Style x:Key="NavBtn" TargetType="RadioButton">
            <Setter Property="Background"    Value="Transparent"/>
            <Setter Property="Foreground"    Value="{StaticResource TextMid}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"        Value="Hand"/>
            <Setter Property="FontFamily"    Value="{StaticResource JF}"/>
            <Setter Property="FontSize"      Value="10"/>
            <Setter Property="Padding"       Value="12,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bg" Background="Transparent" BorderThickness="0">
                            <Grid>
                                <Rectangle x:Name="Bar" Width="2" HorizontalAlignment="Left"
                                           Fill="{StaticResource AccentBrush}" Opacity="0"/>
                                <StackPanel Orientation="Horizontal" Margin="{TemplateBinding Padding}">
                                    <TextBlock x:Name="Ico" Text="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}"
                                               FontSize="13" Width="20" VerticalAlignment="Center"
                                               Foreground="{TemplateBinding Foreground}"/>
                                    <TextBlock Text="{TemplateBinding Content}"
                                               FontFamily="{StaticResource JF}" FontSize="10"
                                               VerticalAlignment="Center" Margin="8,0,0,0"
                                               Foreground="{TemplateBinding Foreground}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bar" Property="Opacity" Value="1"/>
                                <Setter TargetName="Bg"  Property="Background" Value="#1A1A1A"/>
                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#141414"/>
                                <Setter Property="Foreground" Value="{StaticResource TextBright}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Accent button -->
        <Style x:Key="AccBtn" TargetType="Button">
            <Setter Property="Background"    Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground"    Value="#000"/>
            <Setter Property="FontFamily"    Value="{StaticResource JF}"/>
            <Setter Property="FontSize"      Value="10"/>
            <Setter Property="Padding"       Value="16,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"        Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}"
                                CornerRadius="2" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Ghost button -->
        <Style x:Key="GhostBtn" TargetType="Button">
            <Setter Property="Background"    Value="#1A1A1A"/>
            <Setter Property="Foreground"    Value="{StaticResource TextMid}"/>
            <Setter Property="FontFamily"    Value="{StaticResource JF}"/>
            <Setter Property="FontSize"      Value="10"/>
            <Setter Property="Padding"       Value="14,7"/>
            <Setter Property="BorderBrush"   Value="#333"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor"        Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="BorderBrush" Value="#555"/>
                                <Setter Property="Foreground" Value="{StaticResource TextWhite}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Toggle -->
        <Style x:Key="Toggle" TargetType="ToggleButton">
            <Setter Property="Width"  Value="44"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Track" CornerRadius="12" Background="#333">
                            <Ellipse x:Name="Thumb" Width="18" Height="18" Fill="#666"
                                     Margin="3,0" HorizontalAlignment="Left"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="{StaticResource AccentDimBrush}"/>
                                <Setter TargetName="Thumb" Property="Fill" Value="{StaticResource AccentBrush}"/>
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Slider -->
        <Style x:Key="Slider" TargetType="Slider">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton>
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="3" CornerRadius="2" Background="{StaticResource AccentBrush}"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton>
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="3" CornerRadius="2" Background="#2A2A2A"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse Width="13" Height="13" Fill="{StaticResource AccentBrush}"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Technique tag -->
        <Style x:Key="TechTag" TargetType="Border">
            <Setter Property="Background"      Value="#1A1A1A"/>
            <Setter Property="BorderBrush"     Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="3"/>
            <Setter Property="Padding"         Value="8,3"/>
            <Setter Property="Margin"          Value="0,0,6,6"/>
        </Style>

    </Window.Resources>

    <!-- ROOT -->
    <Border Background="{StaticResource Bg0}" BorderBrush="{StaticResource AccentBrush}"
            BorderThickness="1" CornerRadius="0">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="0" Color="#C8FF00" Opacity="0.15"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="28"/>
            </Grid.RowDefinitions>

            <!-- ══════════ TOP BAR ══════════ -->
            <Border Grid.Row="0" Background="{StaticResource Bg1}"
                    BorderBrush="{StaticResource Border1}" BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="TitleBar_MouseDown" Cursor="SizeAll">
                <Grid Margin="12,0">
                    <!-- Left: Logo -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="7" Height="7" Fill="{StaticResource AccentBrush}" Margin="0,0,8,0">
                            <Ellipse.Effect>
                                <DropShadowEffect BlurRadius="8" ShadowDepth="0" Color="#C8FF00" Opacity="1"/>
                            </Ellipse.Effect>
                        </Ellipse>
                        <TextBlock Text="CIPHER . LUA" FontFamily="{StaticResource JF}" FontSize="14"
                                   Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center"/>
                        <Border Background="Transparent" BorderBrush="{StaticResource AccentBrush}"
                                BorderThickness="1" CornerRadius="2" Margin="10,0,6,0" Padding="6,2">
                            <TextBlock Text="V5.0" FontFamily="{StaticResource JF}" FontSize="9"
                                       Foreground="{StaticResource AccentBrush}"/>
                        </Border>
                        <Border Background="{StaticResource AccentBrush}" CornerRadius="2" Padding="6,2">
                            <TextBlock Text="PRO" FontFamily="{StaticResource JF}" FontSize="9" Foreground="#000"/>
                        </Border>
                    </StackPanel>
                    <!-- Right: Status + controls -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Border Background="{StaticResource Bg2}" BorderBrush="{StaticResource Border2}"
                                BorderThickness="1" CornerRadius="2" Padding="8,3" Margin="0,0,12,0">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="6" Height="6" Fill="{StaticResource TagOK}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="All engines nominal" FontFamily="{StaticResource JF}"
                                           FontSize="9" Foreground="{StaticResource TagOK}"/>
                            </StackPanel>
                        </Border>
                        <Button Click="SettingsBtn_Click" Width="28" Height="28" Content="⚙"
                                FontSize="13" Background="Transparent" BorderThickness="0"
                                Foreground="{StaticResource TextMid}" Cursor="Hand" Margin="0,0,4,0"
                                ToolTip="Settings"/>
                        <Button Click="MinimizeBtn_Click" Width="28" Height="28" Content="─"
                                FontSize="11" Background="Transparent" BorderThickness="0"
                                Foreground="{StaticResource TextMid}" Cursor="Hand"/>
                        <Button Click="CloseBtn_Click" Width="28" Height="28" Content="✕"
                                FontSize="11" Background="Transparent" BorderThickness="0"
                                Foreground="{StaticResource TextMid}" Cursor="Hand"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ══════════ BODY ══════════ -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="220"/>
                </Grid.ColumnDefinitions>

                <!-- ──── LEFT SIDEBAR ──── -->
                <Border Grid.Column="0" Background="{StaticResource Bg1}"
                        BorderBrush="{StaticResource Border1}" BorderThickness="0,0,1,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Music Player -->
                        <StackPanel Grid.Row="0" Margin="0,0,0,0">
                            <Border Background="{StaticResource Bg2}" BorderBrush="{StaticResource Border1}"
                                    BorderThickness="0,0,0,1" Padding="12,8">
                                <TextBlock Text="MUSIC PLAYER" FontFamily="{StaticResource JF}"
                                           FontSize="9" Foreground="{StaticResource TextDim}"/>
                            </Border>
                            <StackPanel Margin="12,10">
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Background="{StaticResource Bg2}" BorderBrush="{StaticResource Border2}"
                                            BorderThickness="1" CornerRadius="2">
                                        <TextBox x:Name="YtUrl" Background="Transparent" BorderThickness="0"
                                                 Foreground="{StaticResource TextMid}"
                                                 FontFamily="Consolas" FontSize="10"
                                                 Padding="7,6" Text="https://youtube.com/watch?v=..."/>
                                    </Border>
                                    <Button Grid.Column="1" Style="{StaticResource AccBtn}"
                                            Content="LOAD" Margin="5,0,0,0" Padding="10,7" Click="LoadMusic_Click"/>
                                </Grid>
                                <!-- Thumbnail placeholder -->
                                <Border x:Name="ThumbBorder" Background="{StaticResource Bg3}"
                                        BorderBrush="{StaticResource AccentBrush}" BorderThickness="1"
                                        Height="100" CornerRadius="2" Margin="0,0,0,8">
                                    <TextBlock x:Name="ThumbLabel" Text="♪" FontSize="32"
                                               Foreground="{StaticResource AccentDimBrush}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <!-- Controls -->
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,8">
                                    <Button Content="⏮" Style="{StaticResource GhostBtn}" Width="30" Height="30" Padding="0" FontSize="12" Margin="2,0"/>
                                    <Button x:Name="PlayBtn" Content="▶" Style="{StaticResource AccBtn}" Width="36" Height="36" Padding="0" FontSize="14" Margin="2,0" Click="PlayBtn_Click"/>
                                    <Button Content="⏭" Style="{StaticResource GhostBtn}" Width="30" Height="30" Padding="0" FontSize="12" Margin="2,0"/>
                                    <Button Content="↻" Style="{StaticResource GhostBtn}" Width="30" Height="30" Padding="0" FontSize="14" Margin="2,0"/>
                                    <Button Content="🔇" Style="{StaticResource GhostBtn}" Width="30" Height="30" Padding="0" FontSize="11" Margin="2,0"/>
                                </StackPanel>
                                <!-- Volume -->
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="🔈" FontSize="10" Foreground="{StaticResource TextDim}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <Slider Grid.Column="1" Style="{StaticResource Slider}" Minimum="0" Maximum="100" Value="80" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="80" FontFamily="{StaticResource JF}" FontSize="9" Foreground="{StaticResource AccentBrush}" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                </Grid>
                                <!-- Track name -->
                                <TextBlock x:Name="TrackName" Text="No track loaded"
                                           FontFamily="{StaticResource JF}" FontSize="9"
                                           Foreground="{StaticResource TextMid}"
                                           TextTrimming="CharacterEllipsis"/>
                                <!-- Progress -->
                                <Border Margin="0,6,0,0" Background="{StaticResource Bg2}"
                                        BorderBrush="{StaticResource Border1}" BorderThickness="0,1,0,0" Padding="0,6,0,0">
                                    <StackPanel>
                                        <Grid>
                                            <TextBlock Text="PROGRESS" FontFamily="{StaticResource JF}"
                                                       FontSize="9" Foreground="{StaticResource TextDim}"/>
                                            <TextBlock x:Name="ProgressPct" Text="0%"
                                                       HorizontalAlignment="Right"
                                                       FontFamily="{StaticResource JF}" FontSize="9"
                                                       Foreground="{StaticResource AccentBrush}"/>
                                        </Grid>
                                        <Border Margin="0,4,0,0" Height="4" Background="{StaticResource Bg3}" CornerRadius="2">
                                            <Border x:Name="ProgressFill" HorizontalAlignment="Left"
                                                    Height="4" Width="0" Background="{StaticResource AccentBrush}" CornerRadius="2"/>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </StackPanel>

                        <!-- Detection -->
                        <StackPanel Grid.Row="1">
                            <Border Background="{StaticResource Bg2}" BorderBrush="{StaticResource Border1}"
                                    BorderThickness="0,1,0,1" Padding="12,8">
                                <TextBlock Text="DETECTION" FontFamily="{StaticResource JF}"
                                           FontSize="9" Foreground="{StaticResource TextDim}"/>
                            </Border>
                            <Grid Margin="12,10,12,0">
                                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="8"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Background="{StaticResource Bg2}" BorderBrush="{StaticResource Border1}" BorderThickness="1" CornerRadius="2" Padding="8,8">
                                    <StackPanel>
                                        <TextBlock x:Name="DetObfuscator" Text="--"
                                                   FontFamily="{StaticResource JF}" FontSize="14"
                                                   Foreground="{StaticResource AccentBrush}"/>
                                        <TextBlock Text="OBFUSCATOR" FontFamily="{StaticResource JF}"
                                                   FontSize="8" Foreground="{StaticResource TextDim}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="2" Background="{StaticResource Bg2}" BorderBrush="{StaticResource Border1}" BorderThickness="1" CornerRadius="2" Padding="8,8">
                                    <StackPanel>
                                        <TextBlock x:Name="DetConfidence" Text="--"
                                                   FontFamily="{StaticResource JF}" FontSize="14"
                                                   Foreground="{StaticResource TagINFO}"/>
                                        <TextBlock Text="CONFIDENCE" FontFamily="{StaticResource JF}"
                                                   FontSize="8" Foreground="{StaticResource TextDim}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                            <Grid Margin="12,6,12,0">
                                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="8"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Background="{StaticResource Bg2}" BorderBrush="{StaticResource Border1}" BorderThickness="1" CornerRadius="2" Padding="8,8">
                                    <StackPanel>
                                        <TextBlock x:Name="DetLines" Text="0"
                                                   FontFamily="{StaticResource JF}" FontSize="14"
                                                   Foreground="{StaticResource TextWhite}"/>
                                        <TextBlock Text="INPUT LINES" FontFamily="{StaticResource JF}"
                                                   FontSize="8" Foreground="{StaticResource TextDim}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="2" Background="{StaticResource Bg2}" BorderBrush="{StaticResource Border1}" BorderThickness="1" CornerRadius="2" Padding="8,8">
                                    <StackPanel>
                                        <TextBlock x:Name="DetRecovery" Text="--"
                                                   FontFamily="{StaticResource JF}" FontSize="14"
                                                   Foreground="{StaticResource TagOK}"/>
                                        <TextBlock Text="EST. RECOVERY" FontFamily="{StaticResource JF}"
                                                   FontSize="8" Foreground="{StaticResource TextDim}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <!-- Techniques Active -->
                            <Border Background="{StaticResource Bg2}" BorderBrush="{StaticResource Border1}"
                                    BorderThickness="0,1,0,1" Padding="12,8" Margin="0,10,0,0">
                                <TextBlock Text="TECHNIQUES ACTIVE" FontFamily="{StaticResource JF}"
                                           FontSize="9" Foreground="{StaticResource TextDim}"/>
                            </Border>
                            <WrapPanel x:Name="TechniquesPanel" Margin="12,8,12,8">
                                <!-- filled by code -->
                            </WrapPanel>
                        </StackPanel>

                        <!-- Nav -->
                        <StackPanel Grid.Row="2">
                            <Border Background="{StaticResource Bg2}" BorderBrush="{StaticResource Border1}"
                                    BorderThickness="0,1,0,1" Padding="12,6">
                                <TextBlock Text="TOOLS" FontFamily="{StaticResource JF}"
                                           FontSize="9" Foreground="{StaticResource TextDim}"/>
                            </Border>
                            <RadioButton Style="{StaticResource NavBtn}" Content="Source Editor" Tag="◈"
                                         GroupName="Nav" IsChecked="True" Checked="Nav_Checked" x:Name="NavEditor"/>
                            <RadioButton Style="{StaticResource NavBtn}" Content="FPS Booster" Tag="⚡"
                                         GroupName="Nav" Checked="Nav_Checked" x:Name="NavFPS"/>
                            <RadioButton Style="{StaticResource NavBtn}" Content="Shaders" Tag="✦"
                                         GroupName="Nav" Checked="Nav_Checked" x:Name="NavShaders"/>
                            <RadioButton Style="{StaticResource NavBtn}" Content="AI Assistant" Tag="◉"
                                         GroupName="Nav" Checked="Nav_Checked" x:Name="NavAI"/>
                            <RadioButton Style="{StaticResource NavBtn}" Content="Auto Clicker" Tag="◎"
                                         GroupName="Nav" Checked="Nav_Checked" x:Name="NavAutoClick"/>
                            <RadioButton Style="{StaticResource NavBtn}" Content="Macros" Tag="⌘"
                                         GroupName="Nav" Checked="Nav_Checked" x:Name="NavMacros"/>
                            <RadioButton Style="{StaticResource NavBtn}" Content="Game Helper" Tag="▣"
                                         GroupName="Nav" Checked="Nav_Checked" x:Name="NavGameHelper"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ──── CENTER PANEL ──── -->
                <Border Grid.Column="1" Background="{StaticResource Bg0}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="38"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="36"/>
                        </Grid.RowDefinitions>

                        <!-- Tab bar -->
                        <Border Grid.Row="0" Background="{StaticResource Bg1}"
                                BorderBrush="{StaticResource Border1}" BorderThickness="0,0,0,1">
                            <Grid Margin="10,0">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Ellipse Width="7" Height="7" Fill="{StaticResource AccentBrush}" Margin="0,0,8,0">
                                        <Ellipse.Effect>
                                            <DropShadowEffect BlurRadius="6" ShadowDepth="0" Color="#C8FF00" Opacity="1"/>
                                        </Ellipse.Effect>
                                    </Ellipse>
                                    <TextBlock x:Name="TabTitle" Text="Source Editor"
                                               FontFamily="{StaticResource JF}" FontSize="11"
                                               Foreground="{StaticResource TextBright}" VerticalAlignment="Center"/>
                                </StackPanel>
                                <!-- Editor toolbar (only visible on editor page) -->
                                <StackPanel x:Name="EditorToolbar" Orientation="Horizontal"
                                            HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <Border Background="{StaticResource Bg2}" BorderBrush="{StaticResource Border2}"
                                            BorderThickness="1" CornerRadius="2" Padding="6,3" Margin="0,0,6,0">
                                        <TextBlock Text="⌘ K  clear" FontFamily="{StaticResource JF}"
                                                   FontSize="9" Foreground="{StaticResource TextDim}"/>
                                    </Border>
                                    <Border Background="{StaticResource Bg2}" BorderBrush="{StaticResource Border2}"
                                            BorderThickness="1" CornerRadius="2" Padding="6,3">
                                        <TextBlock Text="⌘ ↵  run" FontFamily="{StaticResource JF}"
                                                   FontSize="9" Foreground="{StaticResource TextDim}"/>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Page content area -->
                        <Grid Grid.Row="1">

                            <!-- SOURCE EDITOR PAGE -->
                            <Grid x:Name="PageEditor" Visibility="Visible">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="1"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Input -->
                                <Grid Grid.Column="0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="32"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <Border Grid.Row="0" Background="{StaticResource Bg2}"
                                            BorderBrush="{StaticResource Border1}" BorderThickness="0,0,0,1">
                                        <StackPanel Orientation="Horizontal" Margin="10,0" VerticalAlignment="Center">
                                            <TextBlock Text="INPUT" FontFamily="{StaticResource JF}"
                                                       FontSize="9" Foreground="{StaticResource TextDim}" VerticalAlignment="Center"/>
                                            <Border Background="{StaticResource TagERR}" CornerRadius="2"
                                                    Padding="6,2" Margin="8,0,0,0">
                                                <TextBlock Text="OBFUSCATED" FontFamily="{StaticResource JF}"
                                                           FontSize="8" Foreground="#000"/>
                                            </Border>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                                        Margin="8,0,0,0" VerticalAlignment="Center">
                                                <Button Content="🗑" Style="{StaticResource GhostBtn}"
                                                        Width="26" Height="22" Padding="0" FontSize="11"
                                                        Margin="0,0,4,0" Click="ClearInput_Click"/>
                                                <Button Content="📂" Style="{StaticResource GhostBtn}"
                                                        Width="26" Height="22" Padding="0" FontSize="11"
                                                        Click="OpenFile_Click"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                    <TextBox Grid.Row="1" x:Name="InputBox"
                                             Background="{StaticResource Bg0}"
                                             Foreground="{StaticResource TextBright}"
                                             FontFamily="Consolas" FontSize="12"
                                             BorderThickness="0" Padding="12"
                                             VerticalScrollBarVisibility="Auto"
                                             HorizontalScrollBarVisibility="Auto"
                                             AcceptsReturn="True" AcceptsTab="True"
                                             TextWrapping="NoWrap"
                                             TextChanged="InputBox_TextChanged"
                                             CaretBrush="{StaticResource AccentBrush}"/>
                                </Grid>

                                <!-- Divider -->
                                <Border Grid.Column="1" Background="{StaticResource Border1}"/>

                                <!-- Output -->
                                <Grid Grid.Column="2">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="32"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <Border Grid.Row="0" Background="{StaticResource Bg2}"
                                            BorderBrush="{StaticResource Border1}" BorderThickness="0,0,0,1">
                                        <StackPanel Orientation="Horizontal" Margin="10,0" VerticalAlignment="Center">
                                            <TextBlock Text="OUTPUT" FontFamily="{StaticResource JF}"
                                                       FontSize="9" Foreground="{StaticResource TextDim}" VerticalAlignment="Center"/>
                                            <Border Background="{StaticResource TagOK}" CornerRadius="2"
                                                    Padding="6,2" Margin="8,0,0,0">
                                                <TextBlock Text="DEOBFUSCATED" FontFamily="{StaticResource JF}"
                                                           FontSize="8" Foreground="#000"/>
                                            </Border>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                                        Margin="8,0,0,0" VerticalAlignment="Center">
                                                <Button Content="⬆" Style="{StaticResource GhostBtn}"
                                                        Width="26" Height="22" Padding="0" FontSize="11" Margin="0,0,4,0"/>
                                                <Button Content="⬇" Style="{StaticResource GhostBtn}"
                                                        Width="26" Height="22" Padding="0" FontSize="11"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                    <TextBox Grid.Row="1" x:Name="OutputBox"
                                             Background="{StaticResource Bg0}"
                                             Foreground="{StaticResource TextBright}"
                                             FontFamily="Consolas" FontSize="12"
                                             BorderThickness="0" Padding="12"
                                             IsReadOnly="True"
                                             VerticalScrollBarVisibility="Auto"
                                             HorizontalScrollBarVisibility="Auto"
                                             AcceptsReturn="True"
                                             TextWrapping="NoWrap"
                                             CaretBrush="{StaticResource AccentBrush}"/>
                                </Grid>
                            </Grid>

                            <!-- FPS BOOSTER PAGE -->
                            <ScrollViewer x:Name="PageFPS" Visibility="Collapsed"
                                          VerticalScrollBarVisibility="Auto" Padding="20">
                                <StackPanel>
                                    <TextBlock Text="FPS BOOSTER" FontFamily="{StaticResource JF}"
                                               FontSize="20" Foreground="{StaticResource AccentBrush}" Margin="0,0,0,4"/>
                                    <TextBlock Text="Optimize Roblox for smoother gameplay. All changes are external — no injection."
                                               FontFamily="{StaticResource JF}" FontSize="9"
                                               Foreground="{StaticResource TextMid}" Margin="0,0,0,20"/>
                                    <Border Background="{StaticResource Bg1}" BorderBrush="{StaticResource Border1}"
                                            BorderThickness="1" CornerRadius="2" Padding="16" Margin="0,0,0,12">
                                        <StackPanel>
                                            <TextBlock Text="PERFORMANCE OPTIONS" FontFamily="{StaticResource JF}"
                                                       FontSize="9" Foreground="{StaticResource TextDim}" Margin="0,0,0,14"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                                <ToggleButton Style="{StaticResource Toggle}" IsChecked="True"/>
                                                <StackPanel Margin="12,0">
                                                    <TextBlock Text="Disable Shadows" FontFamily="{StaticResource JF}"
                                                               FontSize="10" Foreground="{StaticResource TextWhite}"/>
                                                    <TextBlock Text="Major FPS boost on low-end hardware"
                                                               FontSize="10" Foreground="{StaticResource TextDim}"/>
                                                </StackPanel>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                                <ToggleButton Style="{StaticResource Toggle}"/>
                                                <StackPanel Margin="12,0">
                                                    <TextBlock Text="Disable Textures" FontFamily="{StaticResource JF}"
                                                               FontSize="10" Foreground="{StaticResource TextWhite}"/>
                                                    <TextBlock Text="Remove all textures for maximum performance"
                                                               FontSize="10" Foreground="{StaticResource TextDim}"/>
                                                </StackPanel>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                                <ToggleButton Style="{StaticResource Toggle}" IsChecked="True"/>
                                                <StackPanel Margin="12,0">
                                                    <TextBlock Text="High Process Priority" FontFamily="{StaticResource JF}"
                                                               FontSize="10" Foreground="{StaticResource TextWhite}"/>
                                                    <TextBlock Text="Give Roblox more CPU resources"
                                                               FontSize="10" Foreground="{StaticResource TextDim}"/>
                                                </StackPanel>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <ToggleButton Style="{StaticResource Toggle}"/>
                                                <StackPanel Margin="12,0">
                                                    <TextBlock Text="Cap FPS at 60" FontFamily="{StaticResource JF}"
                                                               FontSize="10" Foreground="{StaticResource TextWhite}"/>
                                                    <TextBlock Text="Reduce CPU/GPU usage on fast machines"
                                                               FontSize="10" Foreground="{StaticResource TextDim}"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                    <Button Style="{StaticResource AccBtn}" Content="⚡  APPLY FPS BOOST"
                                            HorizontalAlignment="Left" Padding="20,10" Click="ApplyFPS_Click"/>
                                </StackPanel>
                            </ScrollViewer>

                            <!-- SHADERS PAGE -->
                            <ScrollViewer x:Name="PageShaders" Visibility="Collapsed"
                                          VerticalScrollBarVisibility="Auto" Padding="20">
                                <StackPanel>
                                    <TextBlock Text="SHADERS" FontFamily="{StaticResource JF}"
                                               FontSize="20" Foreground="{StaticResource AccentBrush}" Margin="0,0,0,4"/>
                                    <TextBlock Text="Post-processing visual enhancements via ReShade. Select a preset or fine-tune manually."
                                               FontFamily="{StaticResource JF}" FontSize="9"
                                               Foreground="{StaticResource TextMid}" Margin="0,0,0,20"/>
                                    <Border Background="{StaticResource Bg1}" BorderBrush="{StaticResource Border1}"
                                            BorderThickness="1" CornerRadius="2" Padding="16" Margin="0,0,0,12">
                                        <StackPanel>
                                            <TextBlock Text="PRESETS" FontFamily="{StaticResource JF}"
                                                       FontSize="9" Foreground="{StaticResource TextDim}" Margin="0,0,0,12"/>
                                            <WrapPanel>
                                                <Border x:Name="ShaderCinematic" Background="{StaticResource Bg2}"
                                                        BorderBrush="{StaticResource AccentBrush}" BorderThickness="1"
                                                        CornerRadius="2" Padding="14,8" Margin="0,0,8,8" Cursor="Hand">
                                                    <StackPanel>
                                                        <TextBlock Text="🌅  CINEMATIC" FontFamily="{StaticResource JF}"
                                                                   FontSize="10" Foreground="{StaticResource AccentBrush}"/>
                                                        <TextBlock Text="Warm, filmic look" FontSize="10"
                                                                   Foreground="{StaticResource TextDim}"/>
                                                    </StackPanel>
                                                </Border>
                                                <Border Background="{StaticResource Bg2}" BorderBrush="{StaticResource Border2}"
                                                        BorderThickness="1" CornerRadius="2" Padding="14,8"
                                                        Margin="0,0,8,8" Cursor="Hand">
                                                    <StackPanel>
                                                        <TextBlock Text="🌙  NIGHT MODE" FontFamily="{StaticResource JF}"
                                                                   FontSize="10" Foreground="{StaticResource TextBright}"/>
                                                        <TextBlock Text="Dark, moody atmosphere" FontSize="10"
                                                                   Foreground="{StaticResource TextDim}"/>
                                                    </StackPanel>
                                                </Border>
                                                <Border Background="{StaticResource Bg2}" BorderBrush="{StaticResource Border2}"
                                                        BorderThickness="1" CornerRadius="2" Padding="14,8"
                                                        Margin="0,0,8,8" Cursor="Hand">
                                                    <StackPanel>
                                                        <TextBlock Text="✨  VIBRANT" FontFamily="{StaticResource JF}"
                                                                   FontSize="10" Foreground="{StaticResource TextBright}"/>
                                                        <TextBlock Text="Saturated, vivid colors" FontSize="10"
                                                                   Foreground="{StaticResource TextDim}"/>
                                                    </StackPanel>
                                                </Border>
                                                <Border Background="{StaticResource Bg2}" BorderBrush="{StaticResource Border2}"
                                                        BorderThickness="1" CornerRadius="2" Padding="14,8"
                                                        Margin="0,0,8,8" Cursor="Hand">
                                                    <StackPanel>
                                                        <TextBlock Text="⬜  VANILLA" FontFamily="{StaticResource JF}"
                                                                   FontSize="10" Foreground="{StaticResource TextBright}"/>
                                                        <TextBlock Text="No shaders, default look" FontSize="10"
                                                                   Foreground="{StaticResource TextDim}"/>
                                                    </StackPanel>
                                                </Border>
                                            </WrapPanel>
                                        </StackPanel>
                                    </Border>
                                    <Border Background="{StaticResource Bg1}" BorderBrush="{StaticResource Border1}"
                                            BorderThickness="1" CornerRadius="2" Padding="16">
                                        <StackPanel>
                                            <TextBlock Text="FINE TUNE" FontFamily="{StaticResource JF}"
                                                       FontSize="9" Foreground="{StaticResource TextDim}" Margin="0,0,0,12"/>
                                            <Grid Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="80"/></Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock Text="BRIGHTNESS" FontFamily="{StaticResource JF}" FontSize="8"
                                                               Foreground="{StaticResource TextDim}" Margin="0,0,0,6"/>
                                                    <Slider Style="{StaticResource Slider}" Minimum="0" Maximum="100" Value="50"/>
                                                </StackPanel>
                                                <TextBlock Grid.Column="1" Text="50%" FontFamily="{StaticResource JF}"
                                                           FontSize="11" Foreground="{StaticResource AccentBrush}"
                                                           HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,0,2"/>
                                            </Grid>
                                            <Grid Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="80"/></Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock Text="CONTRAST" FontFamily="{StaticResource JF}" FontSize="8"
                                                               Foreground="{StaticResource TextDim}" Margin="0,0,0,6"/>
                                                    <Slider Style="{StaticResource Slider}" Minimum="0" Maximum="100" Value="50"/>
                                                </StackPanel>
                                                <TextBlock Grid.Column="1" Text="50%" FontFamily="{StaticResource JF}"
                                                           FontSize="11" Foreground="{StaticResource AccentBrush}"
                                                           HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,0,2"/>
                                            </Grid>
                                            <Grid>
                                                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="80"/></Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock Text="SATURATION" FontFamily="{StaticResource JF}" FontSize="8"
                                                               Foreground="{StaticResource TextDim}" Margin="0,0,0,6"/>
                                                    <Slider Style="{StaticResource Slider}" Minimum="0" Maximum="100" Value="65"/>
                                                </StackPanel>
                                                <TextBlock Grid.Column="1" Text="65%" FontFamily="{StaticResource JF}"
                                                           FontSize="11" Foreground="{StaticResource AccentBrush}"
                                                           HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,0,2"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>

                            <!-- AI ASSISTANT PAGE -->
                            <Grid x:Name="PageAI" Visibility="Collapsed">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Background="{StaticResource Bg1}"
                                        BorderBrush="{StaticResource Border1}" BorderThickness="0,0,0,1" Padding="16,10">
                                    <StackPanel>
                                        <TextBlock Text="AI ASSISTANT" FontFamily="{StaticResource JF}"
                                                   FontSize="16" Foreground="{StaticResource AccentBrush}"/>
                                        <TextBlock Text="Ask anything about Roblox — tips, game strategies, controls, scripts explained."
                                                   FontFamily="{StaticResource JF}" FontSize="8"
                                                   Foreground="{StaticResource TextDim}"/>
                                    </StackPanel>
                                </Border>
                                <ScrollViewer Grid.Row="1" x:Name="ChatScroller"
                                              VerticalScrollBarVisibility="Auto"
                                              Background="{StaticResource Bg0}" Padding="12">
                                    <StackPanel x:Name="ChatMessages">
                                        <Border Background="{StaticResource Bg2}" BorderBrush="{StaticResource AccentDimBrush}"
                                                BorderThickness="1" CornerRadius="2" Padding="12,8" Margin="0,0,80,8">
                                            <TextBlock FontSize="12" TextWrapping="Wrap"
                                                       Foreground="{StaticResource TextBright}"
                                                       FontFamily="Consolas">
                                                <Run Foreground="{StaticResource AccentBrush}" Text="CIPHER.AI &gt; "/>
                                                <Run Text="System online. Ask me anything about Roblox — games, tips, scripting help, strategies. I'm wired in."/>
                                            </TextBlock>
                                        </Border>
                                    </StackPanel>
                                </ScrollViewer>
                                <Border Grid.Row="2" Background="{StaticResource Bg1}"
                                        BorderBrush="{StaticResource Border1}" BorderThickness="0,1,0,0" Padding="10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Background="{StaticResource Bg2}" BorderBrush="{StaticResource Border2}"
                                                BorderThickness="1" CornerRadius="2">
                                            <TextBox x:Name="AIChatInput" Background="Transparent" BorderThickness="0"
                                                     Foreground="{StaticResource TextBright}"
                                                     FontFamily="Consolas" FontSize="12"
                                                     Padding="10,8" CaretBrush="{StaticResource AccentBrush}"
                                                     KeyDown="AIChatInput_KeyDown"/>
                                        </Border>
                                        <Button Grid.Column="1" Style="{StaticResource AccBtn}"
                                                Content="SEND" Margin="8,0,0,0"
                                                Padding="16,8" Click="SendAI_Click"/>
                                    </Grid>
                                </Border>
                            </Grid>

                            <!-- AUTO CLICKER PAGE -->
                            <ScrollViewer x:Name="PageAutoClick" Visibility="Collapsed"
                                          VerticalScrollBarVisibility="Auto" Padding="20">
                                <StackPanel>
                                    <TextBlock Text="AUTO CLICKER" FontFamily="{StaticResource JF}"
                                               FontSize="20" Foreground="{StaticResource AccentBrush}" Margin="0,0,0,4"/>
                                    <TextBlock Text="Automated mouse clicking with custom CPS. Hold hotkey to activate."
                                               FontFamily="{StaticResource JF}" FontSize="9"
                                               Foreground="{StaticResource TextMid}" Margin="0,0,0,20"/>
                                    <Border Background="{StaticResource Bg1}" BorderBrush="{StaticResource Border1}"
                                            BorderThickness="1" CornerRadius="2" Padding="16" Margin="0,0,0,12">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition/><ColumnDefinition Width="16"/><ColumnDefinition/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="CLICKS / SECOND" FontFamily="{StaticResource JF}"
                                                           FontSize="8" Foreground="{StaticResource TextDim}" Margin="0,0,0,8"/>
                                                <Border Background="{StaticResource Bg2}" BorderBrush="{StaticResource AccentBrush}"
                                                        BorderThickness="1" CornerRadius="2">
                                                    <TextBox Background="Transparent" BorderThickness="0"
                                                             Text="10" FontFamily="{StaticResource JF}" FontSize="26"
                                                             Foreground="{StaticResource AccentBrush}"
                                                             HorizontalContentAlignment="Center" Padding="0,10"
                                                             CaretBrush="{StaticResource AccentBrush}"/>
                                                </Border>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="BUTTON" FontFamily="{StaticResource JF}"
                                                           FontSize="8" Foreground="{StaticResource TextDim}" Margin="0,0,0,8"/>
                                                <Border Background="{StaticResource Bg2}" BorderBrush="{StaticResource Border2}"
                                                        BorderThickness="1" CornerRadius="2" Padding="12,10">
                                                    <TextBlock Text="LEFT CLICK" FontFamily="{StaticResource JF}"
                                                               FontSize="11" Foreground="{StaticResource TextBright}"/>
                                                </Border>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                    <Border Background="{StaticResource Bg1}" BorderBrush="{StaticResource Border1}"
                                            BorderThickness="1" CornerRadius="2" Padding="16" Margin="0,0,0,12">
                                        <StackPanel>
                                            <TextBlock Text="ACTIVATE HOTKEY" FontFamily="{StaticResource JF}"
                                                       FontSize="8" Foreground="{StaticResource TextDim}" Margin="0,0,0,8"/>
                                            <Border Background="{StaticResource Bg2}" BorderBrush="{StaticResource AccentBrush}"
                                                    BorderThickness="1" CornerRadius="2" Padding="14,8" HorizontalAlignment="Left">
                                                <TextBlock Text="F6" FontFamily="{StaticResource JF}"
                                                           FontSize="16" Foreground="{StaticResource AccentBrush}"/>
                                            </Border>
                                        </StackPanel>
                                    </Border>
                                    <Button Style="{StaticResource AccBtn}" Content="◎  START AUTO CLICKER"
                                            HorizontalAlignment="Left" Padding="20,10"/>
                                </StackPanel>
                            </ScrollViewer>

                            <!-- MACROS PAGE -->
                            <ScrollViewer x:Name="PageMacros" Visibility="Collapsed"
                                          VerticalScrollBarVisibility="Auto" Padding="20">
                                <StackPanel>
                                    <TextBlock Text="MACROS" FontFamily="{StaticResource JF}"
                                               FontSize="20" Foreground="{StaticResource AccentBrush}" Margin="0,0,0,4"/>
                                    <TextBlock Text="Record and replay keyboard/mouse sequences with hotkey triggers."
                                               FontFamily="{StaticResource JF}" FontSize="9"
                                               Foreground="{StaticResource TextMid}" Margin="0,0,0,20"/>
                                    <Border Background="{StaticResource Bg1}" BorderBrush="{StaticResource Border1}"
                                            BorderThickness="1" CornerRadius="2" Padding="16">
                                        <StackPanel>
                                            <Grid Margin="0,0,0,12">
                                                <TextBlock Text="SAVED MACROS" FontFamily="{StaticResource JF}"
                                                           FontSize="9" Foreground="{StaticResource TextDim}"/>
                                                <Button Style="{StaticResource AccBtn}" Content="+ NEW MACRO"
                                                        HorizontalAlignment="Right" Padding="12,5"/>
                                            </Grid>
                                            <Border Background="{StaticResource Bg2}" BorderBrush="{StaticResource Border2}"
                                                    BorderThickness="1" CornerRadius="2" Padding="12">
                                                <Grid>
                                                    <StackPanel>
                                                        <TextBlock Text="Jump Spam" FontFamily="{StaticResource JF}"
                                                                   FontSize="11" Foreground="{StaticResource TextWhite}"/>
                                                        <TextBlock Text="Space × 5   Hotkey: F5" FontSize="10"
                                                                   Foreground="{StaticResource TextDim}" Margin="0,3,0,0"
                                                                   FontFamily="Consolas"/>
                                                    </StackPanel>
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                        <Button Style="{StaticResource AccBtn}" Content="▶  RUN"
                                                                Padding="10,5" Margin="0,0,6,0"/>
                                                        <Button Style="{StaticResource GhostBtn}" Content="EDIT" Padding="10,5"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>

                            <!-- GAME HELPER PAGE -->
                            <ScrollViewer x:Name="PageGameHelper" Visibility="Collapsed"
                                          VerticalScrollBarVisibility="Auto" Padding="20">
                                <StackPanel>
                                    <TextBlock Text="GAME HELPER" FontFamily="{StaticResource JF}"
                                               FontSize="20" Foreground="{StaticResource AccentBrush}" Margin="0,0,0,4"/>
                                    <TextBlock Text="Auto-detects your running Roblox game and answers questions about it."
                                               FontFamily="{StaticResource JF}" FontSize="9"
                                               Foreground="{StaticResource TextMid}" Margin="0,0,0,20"/>
                                    <Border Background="{StaticResource Bg1}" BorderBrush="{StaticResource Border1}"
                                            BorderThickness="1" CornerRadius="2" Padding="16" Margin="0,0,0,12">
                                        <Grid>
                                            <StackPanel>
                                                <TextBlock Text="DETECTED GAME" FontFamily="{StaticResource JF}"
                                                           FontSize="8" Foreground="{StaticResource TextDim}" Margin="0,0,0,6"/>
                                                <TextBlock x:Name="DetectedGame" Text="No game detected — launch Roblox"
                                                           FontFamily="{StaticResource JF}" FontSize="14"
                                                           Foreground="{StaticResource TextWhite}"/>
                                            </StackPanel>
                                            <Button Style="{StaticResource GhostBtn}" Content="↺  REFRESH"
                                                    HorizontalAlignment="Right" Padding="12,6"
                                                    Click="RefreshGame_Click"/>
                                        </Grid>
                                    </Border>
                                    <Border Background="{StaticResource Bg1}" BorderBrush="{StaticResource Border1}"
                                            BorderThickness="1" CornerRadius="2" Padding="16">
                                        <StackPanel>
                                            <TextBlock Text="ASK ABOUT THIS GAME" FontFamily="{StaticResource JF}"
                                                       FontSize="9" Foreground="{StaticResource TextDim}" Margin="0,0,0,10"/>
                                            <Border Background="{StaticResource Bg2}" BorderBrush="{StaticResource Border2}"
                                                    BorderThickness="1" CornerRadius="2" Margin="0,0,0,8">
                                                <TextBox Background="Transparent" BorderThickness="0"
                                                         Foreground="{StaticResource TextBright}"
                                                         FontFamily="Consolas" FontSize="12" Padding="10,8"
                                                         CaretBrush="{StaticResource AccentBrush}"
                                                         Text="e.g. How do I find the secret room?"/>
                                            </Border>
                                            <Button Style="{StaticResource AccBtn}" Content="◉  GET HELP" HorizontalAlignment="Left"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>

                        </Grid>

                        <!-- Footer bar (Editor) -->
                        <Border Grid.Row="2" Background="{StaticResource Bg1}"
                                BorderBrush="{StaticResource Border1}" BorderThickness="0,1,0,0">
                            <Grid Margin="10,0">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock x:Name="FooterLines" Text="Lines: 0  Chars: 0"
                                               FontFamily="{StaticResource JF}" FontSize="9"
                                               Foreground="{StaticResource TextDim}" Margin="0,0,16,0"/>
                                    <TextBlock x:Name="FooterTime" Text="Time: --"
                                               FontFamily="{StaticResource JF}" FontSize="9"
                                               Foreground="{StaticResource TextDim}"/>
                                </StackPanel>
                                <!-- Waveform decoration -->
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Style="{StaticResource AccBtn}" Content="▶  RUN DEOBFUSCATOR"
                                            Padding="16,6" Click="RunDeobfuscator_Click"
                                            x:Name="RunBtn" Visibility="Visible"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <!-- ──── RIGHT PANEL: SYSTEM LOG ──── -->
                <Border Grid.Column="2" Background="{StaticResource Bg1}"
                        BorderBrush="{StaticResource Border1}" BorderThickness="1,0,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="36"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Background="{StaticResource Bg2}"
                                BorderBrush="{StaticResource Border1}" BorderThickness="0,0,0,1">
                            <Grid Margin="12,0">
                                <TextBlock Text="SYSTEM LOG" FontFamily="{StaticResource JF}"
                                           FontSize="10" Foreground="{StaticResource TextBright}"
                                           VerticalAlignment="Center"/>
                                <Button HorizontalAlignment="Right" Content="CLEAR"
                                        Click="ClearLog_Click"
                                        Background="Transparent" BorderThickness="0"
                                        FontFamily="{StaticResource JF}" FontSize="9"
                                        Foreground="{StaticResource TextDim}" Cursor="Hand"
                                        VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ScrollViewer Grid.Row="1" x:Name="LogScroller"
                                      VerticalScrollBarVisibility="Auto"
                                      Background="{StaticResource Bg1}" Padding="8">
                            <StackPanel x:Name="LogPanel"/>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>

            <!-- ══════════ BOTTOM BAR ══════════ -->
            <Border Grid.Row="2" Background="{StaticResource Bg1}"
                    BorderBrush="{StaticResource Border1}" BorderThickness="0,1,0,0">
                <Grid Margin="12,0">
                    <TextBlock Text="CIPHER.LUA v5.0  —  External overlay. No injection. Safe."
                               FontFamily="{StaticResource JF}" FontSize="8"
                               Foreground="{StaticResource TextDim}" VerticalAlignment="Center"/>
                    <TextBlock Text="github.com/YOUR_USERNAME/CipherLua"
                               HorizontalAlignment="Right"
                               FontFamily="{StaticResource JF}" FontSize="8"
                               Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
