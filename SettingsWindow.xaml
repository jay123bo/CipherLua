<Window x:Class="CipherLua.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CIPHER.LUA — Settings"
        Height="480" Width="420"
        WindowStartupLocation="CenterOwner"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None"
        ResizeMode="NoResize">
    <Border Background="#0D0D0D" BorderBrush="#C8FF00" BorderThickness="1" CornerRadius="4">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="0" Color="#C8FF00" Opacity="0.3"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="42"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="52"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Border Grid.Row="0" Background="#141414" BorderBrush="#2A2A2A" BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="TitleBar_MouseDown" Cursor="SizeAll">
                <Grid Margin="16,0">
                    <TextBlock Text="SETTINGS" FontFamily="/CipherLua;component/Fonts/Jokerman.otf#Jokerman"
                               FontSize="13" Foreground="#C8FF00" VerticalAlignment="Center"/>
                    <Button Click="CloseBtn_Click" HorizontalAlignment="Right" Width="28" Height="28"
                            Content="✕" FontSize="12" Background="Transparent" BorderThickness="0"
                            Foreground="#888" Cursor="Hand"/>
                </Grid>
            </Border>

            <!-- Content -->
            <StackPanel Grid.Row="1" Margin="20,16">

                <!-- Accent Color -->
                <TextBlock Text="ACCENT COLOR" FontFamily="/CipherLua;component/Fonts/Jokerman.otf#Jokerman"
                           FontSize="10" Foreground="#666" Margin="0,0,0,12"/>

                <WrapPanel Margin="0,0,0,24" x:Name="ColorSwatches">
                    <!-- Swatches built in code-behind -->
                </WrapPanel>

                <!-- Custom Hex -->
                <TextBlock Text="CUSTOM HEX COLOR" FontFamily="/CipherLua;component/Fonts/Jokerman.otf#Jokerman"
                           FontSize="10" Foreground="#666" Margin="0,0,0,8"/>
                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Background="#1A1A1A" BorderBrush="#333" BorderThickness="1" CornerRadius="3">
                        <TextBox x:Name="HexInput" Background="Transparent" BorderThickness="0"
                                 Foreground="#EEE" FontFamily="Consolas" FontSize="13"
                                 Padding="10,8" Text="#C8FF00" VerticalAlignment="Center"
                                 MaxLength="7"/>
                    </Border>
                    <Button Grid.Column="1" x:Name="ApplyHexBtn" Content="APPLY"
                            Click="ApplyHex_Click" Margin="8,0,0,0"
                            Background="#C8FF00" Foreground="#000"
                            FontFamily="/CipherLua;component/Fonts/Jokerman.otf#Jokerman"
                            FontSize="10" Padding="14,8" BorderThickness="0" Cursor="Hand"/>
                </Grid>

                <!-- Preview -->
                <TextBlock Text="PREVIEW" FontFamily="/CipherLua;component/Fonts/Jokerman.otf#Jokerman"
                           FontSize="10" Foreground="#666" Margin="0,0,0,8"/>
                <Border x:Name="PreviewBorder" Background="#141414" BorderThickness="1"
                        CornerRadius="3" Padding="14,10">
                    <StackPanel>
                        <TextBlock x:Name="PreviewText" Text="• CIPHER.LUA  v5.0"
                                   FontFamily="/CipherLua;component/Fonts/Jokerman.otf#Jokerman"
                                   FontSize="14" Foreground="#C8FF00"/>
                        <TextBlock Text="All engines nominal" FontSize="11" Foreground="#888" Margin="0,4,0,0"
                                   FontFamily="/CipherLua;component/Fonts/Jokerman.otf#Jokerman"/>
                    </StackPanel>
                </Border>

                <!-- Other toggles -->
                <TextBlock Text="OPTIONS" FontFamily="/CipherLua;component/Fonts/Jokerman.otf#Jokerman"
                           FontSize="10" Foreground="#666" Margin="0,20,0,12"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <CheckBox x:Name="GlowCheck" IsChecked="True" VerticalAlignment="Center"/>
                    <TextBlock Text="Enable accent glow effects" FontSize="11" Foreground="#AAA"
                               Margin="10,0,0,0" VerticalAlignment="Center"
                               FontFamily="/CipherLua;component/Fonts/Jokerman.otf#Jokerman"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <CheckBox x:Name="AnimCheck" IsChecked="True" VerticalAlignment="Center"/>
                    <TextBlock Text="Enable log animations" FontSize="11" Foreground="#AAA"
                               Margin="10,0,0,0" VerticalAlignment="Center"
                               FontFamily="/CipherLua;component/Fonts/Jokerman.otf#Jokerman"/>
                </StackPanel>
            </StackPanel>

            <!-- Footer -->
            <Border Grid.Row="2" Background="#141414" BorderBrush="#2A2A2A" BorderThickness="0,1,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="20,0" VerticalAlignment="Center">
                    <Button Content="CANCEL" Click="CloseBtn_Click" Margin="0,0,10,0"
                            Background="#1A1A1A" Foreground="#888" BorderBrush="#333" BorderThickness="1"
                            FontFamily="/CipherLua;component/Fonts/Jokerman.otf#Jokerman"
                            FontSize="10" Padding="16,8" Cursor="Hand"/>
                    <Button x:Name="SaveBtn" Content="SAVE &amp; APPLY" Click="Save_Click"
                            Background="#C8FF00" Foreground="#000" BorderThickness="0"
                            FontFamily="/CipherLua;component/Fonts/Jokerman.otf#Jokerman"
                            FontSize="10" Padding="16,8" Cursor="Hand"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
